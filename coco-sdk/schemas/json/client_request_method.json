{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClientRequestMethod",
  "description": "Wire-method identifier for every `ClientRequest` variant.\n\nCross-language protocol constant exported to the JSON schema bundle so Python / other SDK codegens obtain the same vocabulary. Consumers should reference `ClientRequestMethod::SessionStart` rather than compare against raw wire strings.",
  "type": "string",
  "enum": [
    "initialize",
    "session/start",
    "session/resume",
    "session/list",
    "session/read",
    "session/archive",
    "session/rename",
    "session/toggleTag",
    "session/cost",
    "session/status",
    "turn/start",
    "turn/interrupt",
    "task/list",
    "task/detail",
    "approval/resolve",
    "input/resolveUserInput",
    "elicitation/resolve",
    "control/setModel",
    "control/setModelRole",
    "control/setPermissionMode",
    "control/setThinking",
    "control/setAgentColor",
    "control/applyPermissionUpdate",
    "control/resetSessionPermissionRules",
    "control/stopTask",
    "control/rewindFiles",
    "control/updateEnv",
    "control/backgroundAllTasks",
    "control/keepAlive",
    "control/cancelRequest",
    "agent/interruptCurrentWork",
    "config/read",
    "config/value/write",
    "mcp/status",
    "context/usage",
    "mcp/setServers",
    "mcp/reconnect",
    "mcp/toggle",
    "plugin/reload",
    "hook/reload",
    "config/applyFlags"
  ]
}